<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme -->
    <style name="Theme.OALevelResources" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.OALevelResources.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FAFAF5</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">#1B5E20</item>
        <item name="postSplashScreenTheme">@style/Theme.OALevelResources</item>
    </style>
</resources>
